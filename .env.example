# Supabase（supabase.com のプロジェクト設定 > API から取得）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# E2E（Playwright）の開始時クリーンアップ専用。RLS をバイパスしてテスト一時データを削除するため
# service-role キーが必要。ブラウザには絶対に露出させないこと（NEXT_PUBLIC_ を付けない）。
# 設定先: .env.local（ローカル）/ CI シークレット。docs/specs/18_e2e_data_lifecycle.md 参照。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
