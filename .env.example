# Supabase（supabase.com のプロジェクト設定 > API から取得）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# サイトの公開URL（認証メールのリンク先オリジンに使用。末尾スラッシュは付けない）。
# 未設定時はリクエストの origin にフォールバックする。本番は Vercel のデプロイURLを設定。
# 例: 本番 https://example.com / ローカル http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# E2E（Playwright）の開始時クリーンアップ専用。RLS をバイパスしてテスト一時データを削除するため
# service-role キーが必要。ブラウザには絶対に露出させないこと（NEXT_PUBLIC_ を付けない）。
# 設定先: .env.local（ローカル）/ CI シークレット。docs/specs/18_e2e_data_lifecycle.md 参照。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
